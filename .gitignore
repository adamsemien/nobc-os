# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# brainstorming visual-companion artifacts (local only)
/.superpowers

# testing
/coverage

# playwright e2e
tests/e2e/.auth/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...except the placeholder example, which carries no secrets and documents required vars.
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/
.agents/
.codex/

# nobc-house-phone is its own git repo (Railway standalone service) — never commit it into nobc-os
/nobc-house-phone/
.env*.local

# clerk configuration (can include secrets)
/.clerk/

# sentry — .env.sentry-build-plugin is already covered by the .env* rule above;
# .sentryclirc can hold an auth token and must never be committed.
.sentryclirc

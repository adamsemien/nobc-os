generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id         String   @id @default(cuid())
  clerkOrgId String   @unique
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // White-label / workspace settings
  logoUrl           String?
  primaryColor      String?
  contactEmail      String?
  tierCharterName   String  @default("Charter")
  tierStandardName  String  @default("Standard")
  tierWaitlistName  String  @default("Waitlist")
  defaultTemplateId String?

  members         Member[]
  applications    Application[]
  events          Event[]
  rsvps           RSVP[]
  tickets         Ticket[]
  payments        Payment[]
  waitlistEntries WaitlistEntry[]
  auditEvents     AuditEvent[]
  redList              RedList[]
  eventFlowTemplates   EventFlowTemplate[]
  questionDefinitions  QuestionDefinition[]
  applicationTemplates ApplicationTemplate[]
  intelligenceInsights IntelligenceInsight[]
  savedReports         SavedReport[]
  agentConversations   AgentConversation[]
  svixAppId       String?
}

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  GUEST
}

model Member {
  id                String       @id @default(cuid())
  workspaceId       String
  workspace         Workspace    @relation(fields: [workspaceId], references: [id])
  clerkUserId       String
  email             String
  firstName         String
  lastName          String
  phone             String?
  status            MemberStatus @default(PENDING)
  tags              String[]
  energyScore       Int?
  networkValueScore Int?
  aiSummary         String?
  redListed         Boolean      @default(false)
  approved          Boolean      @default(false)
  approvedAt        DateTime?
  memberQrCode      String?      @unique
  walletPassId      String?
  passIssuedAt      DateTime?
  totalEventsAttended Int        @default(0)
  lastAttendedDate  DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  rsvps           RSVP[]
  tickets         Ticket[]
  waitlistEntries WaitlistEntry[]

  @@unique([workspaceId, clerkUserId])
  @@unique([workspaceId, email])
  @@index([workspaceId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  HOLD
  WAITLISTED
  DECLINED
}

enum AiApplicationRecommendation {
  strong_yes
  yes
  unclear
  no
  strong_no
}

model Application {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  memberId    String?
  email       String
  fullName    String
  phone        String?
  city         String?
  neighborhood String?
  referredBy   String?
  consentEmail Boolean           @default(false)
  consentSms   Boolean           @default(false)
  status       ApplicationStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewNote  String?
  rejectionReason String?
  aiTags      String[]
  aiScore          Float?
  aiRecommendation AiApplicationRecommendation?
  aiReasoning      String?
  duplicateFlag    Boolean           @default(false)
  archetype        String?
  archetypeScores  Json?
  personalizedCopy String?
  templateId       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  answers  ApplicationAnswer[]
  template ApplicationTemplate? @relation(fields: [templateId], references: [id])

  @@index([workspaceId])
  @@index([templateId])
}

model ApplicationAnswer {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  questionKey   String
  answer        String
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

enum EventAccessMode {
  OPEN
  TICKETED
  APPLY_OR_PAY
}

/// Sub-mode when accessMode is APPLY_OR_PAY (non-member / hybrid flows).
enum EventApplyMode {
  APPROVAL_HOLDS_TICKET
  SUBMIT_CONFIRMS_ENTRY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

model Event {
  id               String          @id @default(cuid())
  workspaceId      String
  workspace        Workspace       @relation(fields: [workspaceId], references: [id])
  slug             String
  title            String
  description      String?
  /// Full public hero image URL (e.g. Vercel Blob). Used directly as img src.
  heroImageAssetId      String?
  startAt          DateTime
  endAt            DateTime?
  location         String?
  /// Optional deep link (Google Maps, Apple Maps, etc.).
  mapsUrl               String?
  capacity         Int?
  accessMode            EventAccessMode @default(OPEN)
  applyMode             EventApplyMode?
  approvalRequired      Boolean         @default(false)
  plusOnesAllowed       Boolean         @default(false)
  status                EventStatus     @default(DRAFT)
  showCapacity          Boolean         @default(false)
  priceInCents          Int?
  nonMemberPriceInCents Int?
  refundWindowHours     Int?
  runOfShow             String?         @db.Text
  template              String          @default("editorial")
  eventAccess           Json            @default("{\"member\":{\"enabled\":true,\"gate\":\"auto_confirm\",\"priceCents\":0},\"guest\":{\"enabled\":false,\"gate\":\"pay\",\"priceCents\":0},\"comp\":{\"enabled\":false,\"budgetCap\":null}}")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  customQuestions EventCustomQuestion[]
  rsvps           RSVP[]
  tickets         Ticket[]
  waitlistEntries WaitlistEntry[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

enum FieldType {
  TEXT
  TEXTAREA
  SELECT
  MULTISELECT
  CHECKBOX
  DATE
  EMAIL
  PHONE
}

enum QuestionFlowStep {
  BEFORE_SUBMIT
  AFTER_PAYMENT
  BEFORE_APPROVAL
}

model EventCustomQuestion {
  id           String           @id @default(cuid())
  eventId      String
  event        Event            @relation(fields: [eventId], references: [id])
  workspaceId  String
  label        String
  fieldType    FieldType
  options      String[]
  required     Boolean          @default(false)
  order        Int
  showToMember Boolean          @default(true)
  showToGuest  Boolean          @default(true)
  whenInFlow   QuestionFlowStep @default(BEFORE_SUBMIT)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([workspaceId])
  @@index([eventId])
}

enum RSVPStatus {
  CONFIRMED
  DECLINED
  WAITLISTED
}

model RSVP {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  eventId     String
  event       Event      @relation(fields: [eventId], references: [id])
  memberId    String
  member      Member     @relation(fields: [memberId], references: [id])
  status             RSVPStatus @default(CONFIRMED)
  ticketStatus       String     @default("confirmed")
  origin             String     @default("direct")
  plusOneOfMemberId  String?
  customAnswers      Json?
  checkedIn          Boolean    @default(false)
  checkedInAt        DateTime?
  stripePaymentIntentId String?
  paymentStatus      String?
  capturedAt         DateTime?
  amountCents        Int?
  refundedAt         DateTime?
  refundAmountCents  Int?
  isComp             Boolean    @default(false)
  compType           String?
  guestEmail         String?
  guestName          String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  tickets Ticket[]

  @@unique([workspaceId, eventId, memberId])
  @@index([workspaceId])
  @@index([eventId])
}

enum TicketStatus {
  AUTHORIZED
  CAPTURED
  REFUNDED
  CANCELLED
}

model Ticket {
  id                    String       @id @default(cuid())
  workspaceId           String
  workspace             Workspace    @relation(fields: [workspaceId], references: [id])
  eventId               String
  event                 Event        @relation(fields: [eventId], references: [id])
  memberId              String
  member                Member       @relation(fields: [memberId], references: [id])
  rsvpId                String
  rsvp                  RSVP         @relation(fields: [rsvpId], references: [id])
  stripePaymentIntentId String?
  amount                Int
  currency              String
  status                TicketStatus
  walletPassId          String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  payments Payment[]

  @@index([workspaceId])
  @@index([eventId])
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

model Payment {
  id                    String        @id @default(cuid())
  workspaceId           String
  workspace             Workspace     @relation(fields: [workspaceId], references: [id])
  ticketId              String
  ticket                Ticket        @relation(fields: [ticketId], references: [id])
  stripePaymentIntentId String
  amount                Int
  currency              String
  status                PaymentStatus
  capturedAt            DateTime?
  refundedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([workspaceId])
  @@index([ticketId])
}

model WaitlistEntry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id])
  memberId    String?
  member      Member?   @relation(fields: [memberId], references: [id])
  email       String
  name        String
  position    Int
  notifiedAt  DateTime?
  claimedAt   DateTime?
  expiresAt   DateTime?
  promotedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([eventId])
}

enum AuditActorType {
  OPERATOR
  AGENT
  MEMBER
  SYSTEM
}

model AuditEvent {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])
  actorId     String?
  actorType   AuditActorType @default(OPERATOR)
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([workspaceId])
  @@index([entityType, entityId])
}

/// A Cmd+K agent session. One per palette agent-mode entry (Phase 1 — no resumption).
model AgentConversation {
  id          String   @id @default(cuid())
  workspaceId String
  operatorId  String
  createdAt   DateTime @default(now())
  lastTurnAt  DateTime @default(now())
  /// Auto-generated from the first user message, max 80 chars.
  title       String?

  turns     AgentTurn[]
  workspace Workspace   @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([operatorId])
}

/// One step in an agent conversation: a user message, an assistant message,
/// a tool call, or a tool result.
model AgentTurn {
  id                 String          @id @default(cuid())
  conversationId     String
  role               AgentTurnRole
  /// User message or assistant text.
  content            String?
  toolName           String?
  toolInput          Json?
  toolOutput         Json?
  status             AgentTurnStatus @default(COMPLETED)
  confirmationPrompt String?
  createdAt          DateTime        @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum AgentTurnRole {
  USER
  ASSISTANT
  TOOL_CALL
  TOOL_RESULT
}

enum AgentTurnStatus {
  PENDING
  AWAITING_CONFIRMATION
  COMPLETED
  CANCELLED
  FAILED
}

model RedList {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  email           String?
  namePattern     String?
  reason          String?
  addedByPersonId String?
  createdAt       DateTime  @default(now())

  @@index([workspaceId])
  @@index([email])
}

model QuestionDefinition {
  id                  String   @id @default(cuid())
  workspaceId         String
  templateId          String
  stableKey           String
  label               String
  type                String
  section             String
  order               Int
  required            Boolean  @default(false)
  isActive            Boolean  @default(true)
  insightLabel        String
  insightDescription  String
  scoringDimension    String?
  scoringWeight       Float    @default(0.5)
  scoringLogic        String
  archetypeSignals    String[]
  sponsorRelevance    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace   Workspace           @relation(fields: [workspaceId], references: [id])
  template    ApplicationTemplate @relation(fields: [templateId], references: [id])

  @@index([workspaceId])
  @@index([templateId])
  @@index([stableKey])
}

model ApplicationTemplate {
  id                    String   @id @default(cuid())
  workspaceId           String
  name                  String
  description           String?
  slug                  String
  isActive              Boolean  @default(true)
  isDefault             Boolean  @default(false)
  scoringInstructions   String
  archetypesEnabled     Boolean  @default(true)
  memberWorthEnabled    Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  workspace    Workspace            @relation(fields: [workspaceId], references: [id])
  questions    QuestionDefinition[]
  applications Application[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model EventFlowTemplate {
  id                    String    @id @default(cuid())
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  name                  String
  accessMode            String
  applyMode             String?
  priceInCents          Int?
  nonMemberPriceInCents Int?
  approvalRequired      Boolean   @default(false)
  plusOnesAllowed       Boolean   @default(false)
  showCapacity          Boolean   @default(false)
  customQuestions       Json      @default("[]")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([workspaceId])
}

model IntelligenceInsight {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  metricId     String
  narrative    String
  delta        Json?
  generatedAt  DateTime  @default(now())
  acknowledged Boolean   @default(false)

  @@index([workspaceId])
  @@index([metricId])
}

model SavedReport {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  question    String
  metricIds   String[]
  filters     Json
  createdById String
  createdAt   DateTime  @default(now())
  lastRunAt   DateTime?

  @@index([workspaceId])
}

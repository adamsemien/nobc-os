  entityTags EntityTag[]
  workspace  Workspace   @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@unique([workspaceId, externalSource, externalId])
  @@index([workspaceId])
  @@index([externalSource])
  @@index([category])
}

model EntityTag {
  id          String        @id @default(cuid())
  workspaceId String
  tagId       String
  entityType  TagEntityType
  entityId    String
  appliedBy   String? // userId, "system", or source name
  appliedAt   DateTime      @default(now())

  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([tagId, entityType, entityId])
  @@index([workspaceId, entityType, entityId])
  @@index([tagId])
}

model SponsorBrandProfile {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  contactEmail String? // primary sponsor contact for recap delivery (additive 2026-06-17)
  icp          String?
  icpTags      String[]
  category     String?
  primaryColor String?
  logoAssetId  String?

  // Sponsor Brief intake (Sponsor Intelligence, Phase 0). Brand-level brief — there is no
  // per-event sponsor model; per-event reproducibility is captured in RecapSnapshot.
  declaredObjectives    String? // sponsor's stated objectives in their own language (Awareness/Affinity/Acquisition/Activation + targets)
  targetPersonaCriteria Json? // persona to match the audience against: { archetypes, industries, seniority, companySizes, minAttendance }
  rightsFeeCents        Int? // sponsorship rights fee in cents (money-as-cents convention) — drives the value-vs-fee multiple

  generatedAssets        GeneratedAsset[]
  recapSnapshots         RecapSnapshot[]
  surveyResponses        SurveyResponse[]
  sponsorScopedQuestions EventCustomQuestion[]
  seriesSponsors         SeriesSponsor[]
  workspace              Workspace             @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

// Frozen, reproducible snapshot of the computed numbers behind an Activation Recap PDF
// (Sponsor Intelligence, Phase 0). Numbers are computed in code and stored here so a
// regenerated PDF and the magic-link always agree. Workspace-scoped.
model RecapSnapshot {
  id                 String               @id @default(cuid())
  workspaceId        String
  workspace          Workspace            @relation(fields: [workspaceId], references: [id])
  eventId            String // soft FK (plain string + index), mirrors Asset.eventId
  sponsorBrandId     String?
  sponsorBrand       SponsorBrandProfile? @relation(fields: [sponsorBrandId], references: [id])
  metrics            Json // frozen computed metrics behind the recap (audience, scan rates, archetype mix, persona match)
  mediaValueInputs   Json // attendeeCount, qualifiedMix, totalReach + the three EMV tier outputs
  generatedAt        DateTime             @default(now())
  generatedBySession String?
  createdAt          DateTime             @default(now())

  @@index([workspaceId])
  @@index([eventId])
  @@index([sponsorBrandId])
}

model GeneratedAsset {
  id                 String    @id @default(cuid())
  workspaceId        String
  sponsorBrandId     String?
  type               String // simple String for now; promote to enum later
  pdfUrl             String
  magicLinkUrl       String    @unique
  generatedAt        DateTime  @default(now())
  generatedBySession String?
  expiresAt          DateTime?
  payload            Json

  sponsorBrand SponsorBrandProfile? @relation(fields: [sponsorBrandId], references: [id])
  workspace    Workspace            @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

// Pre/post/at-activation survey responses (Sponsor Intelligence, Phase 1/2). Powers brand-lift
// (PRE vs POST) and the activation-loop booth capture (ACTIVATION). New CREATE TYPE enum — never
// ALTER an existing enum. Workspace-scoped; eventId is a soft FK (string + index).
enum SurveyPhase {
  PRE
  POST
  ACTIVATION
}

model SurveyResponse {
  id             String               @id @default(cuid())
  workspaceId    String
  workspace      Workspace            @relation(fields: [workspaceId], references: [id])
  eventId        String
  sponsorBrandId String?
  sponsorBrand   SponsorBrandProfile? @relation(fields: [sponsorBrandId], references: [id])
  memberId       String?
  member         Member?              @relation(fields: [memberId], references: [id])
  phase          SurveyPhase
  token          String?              @unique // public submission magic-link token (null for seeded/direct)
  answers        Json                 @default("{}")
  sentAt         DateTime? // set when an invite email is dispatched
  submittedAt    DateTime? // set when the respondent submits
  createdAt      DateTime             @default(now())

  @@index([workspaceId])
  @@index([eventId])
  @@index([sponsorBrandId])
  @@index([memberId])
}

// Internal operator-to-operator notes attached to any entity
// (application / member / event / rsvp / generic). Mentions push into
// OperatorNotification on save.
model OperatorComment {
  id          String    @id @default(cuid())
  workspaceId String
  authorId    String
  authorName  String
  entityType  String
  entityId    String
  body        String
  mentions    String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, createdAt])
}

// Internal notifications surfaced in the operator top-bar bell.
// Read state is per-recipient; createdAt is the canonical sort key.
model OperatorNotification {
  id          String    @id @default(cuid())
  workspaceId String
  recipientId String
  type        String
  title       String
  body        String?
  link        String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([recipientId, readAt])
  @@index([workspaceId, createdAt])
}

// Gamified QA testing missions. AI generates a scenario + steps; operator runs
// it in the live platform; checkpoint hits + bug reports + completion accrue
// score. Mission state is honor-system + URL detection on the client.
model QAMission {
  id             String    @id @default(cuid())
  workspaceId    String
  operatorId     String
  operatorName   String
  scenario       String
  missionType    String // 'speed_run' | 'discovery' | 'workflow' | 'stress_test' | 'bug_hunt'
  difficulty     String // 'easy' | 'medium' | 'hard'
  targetSteps    Json // Array of { id, instruction, checkpoint, points }
  completedSteps Json      @default("[]")
  score          Int       @default(0)
  bugsFound      Json      @default("[]")
  feedback       String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMs     Int?
  status         String    @default("active") // 'active' | 'completed' | 'abandoned'

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, operatorId])
  @@index([workspaceId, status])
  @@index([workspaceId, score])
}

// Workspace-defined membership tiers — replaces the hardcoded top/mid/low
// buckets. Order is operator-controlled (lowest tier = order 0). minScore
// (0–1 canonical aiScore) keeps the bucket/gate semantics derivable from a
// member's score; setting it null means anyone qualifies.
model MembershipTier {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  order       Int       @default(0)
  minScore    Float?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, order])
}

// House Phone — shared multi-operator SMS inbox for live events.
// Direct Twilio send/receive (see the Twilio override note in CLAUDE.md, 2026-05-22).
enum SmsDirection {
  INBOUND
  OUTBOUND
}

model SmsConversation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  phone       String
  name        String?
  eventId     String?
  event       Event?    @relation(fields: [eventId], references: [id])
  aiEnabled   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Slice 3 (Communicate + log it): identity link, dual-pointer per the Slice 0/1
  // pattern. Nullable — House Phone (Railway) mints these rows for a bare phone
  // number with no Person/Member resolution of its own; nobc-os fills these in via
  // lazy resolve-on-read (GET /api/sms/conversations), never at write time. A Blast
  // SMS send (lib/blast/run.ts's logSmsToInbox) is the one write-time exception —
  // it already has a resolved memberId in hand and stamps it fill-if-empty.
  memberId String?
  member   Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  personId String?
  person   Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)

  messages SmsMessage[]

  @@unique([workspaceId, phone])
  @@index([workspaceId])
  @@index([memberId])
  @@index([personId])
}

model SmsMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   SmsConversation @relation(fields: [conversationId], references: [id])
  direction      SmsDirection
  body           String          @db.Text
  aiGenerated    Boolean         @default(false)
  // AI topic label for inbound messages (e.g. "Parking", "Guest List").
  // Null until the categorization job (GET /api/sms/categorize) processes it.
  category       String?
  createdAt      DateTime        @default(now())

  @@index([conversationId, createdAt])
}

/// Per-recipient transactional (Resend) email log — Slice 3 "Communicate + log it".
/// One row per recipient per sendTemplatedEmail() call (lib/email.ts). Not the
/// Blast/marketing path (BlastRecipient already logs that, per-recipient, with its
/// own providerId column). `status` starts at 'sent' or 'failed' and is advanced by
/// the Resend webhook (POST /api/webhooks/resend) as delivery/open/click/bounce/
/// complaint events arrive, matched by (providerId, to) — a single Resend send()
/// call can cover multiple recipients under one shared providerId, so `to` is the
/// tie-breaker for which row a given webhook event belongs to.
model TransactionalEmailLog {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  templateKey String
  to          String
  memberId    String?
  member      Member?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  personId    String?
  person      Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)
  /// Resend's message id (send.data.id). Null on a failed send attempt.
  providerId  String?
  /// sent | failed | delivered | opened | clicked | bounced | complained
  status      String    @default("sent")
  sentAt      DateTime  @default(now())
  openedAt    DateTime?
  clickedAt   DateTime?

  @@index([workspaceId])
  @@index([memberId])
  @@index([personId])
  @@index([providerId])
}

// Append-only log of member engagement signals. Feeds network-capital scoring,
// intelligence, and sponsor reporting. Fire-and-forget writes (lib/engagement.ts).
model MemberEngagementEvent {
  id          String                    @id @default(cuid())
  workspaceId String
  // Phase 2A: activity generalizes to Person; memberId nullable so member-less
  // humans (applicant who never submits) can still accrue activity.
  memberId    String?
  personId    String?
  eventType   MemberEngagementEventType
  eventId     String?
  metadata    Json?
  occurredAt  DateTime                  @default(now())

  member    Member?   @relation(fields: [memberId], references: [id], onDelete: Restrict)
  person    Person?   @relation(fields: [personId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([memberId])
  @@index([personId])
  @@index([occurredAt])
}

enum MemberEngagementEventType {
  rsvp_confirmed
  rsvp_cancelled
  checked_in
  waitlist_joined
  waitlist_promoted
  application_submitted
  newsletter_opened
  sponsor_perk_clicked
  // Added 2026-06-06 (member-intelligence PR1). Each value is added to the DB via
  // a standalone `ALTER TYPE ... ADD VALUE` (see prisma/sql/additive_engagement_enum.sql).
  guest_created
  application_approved
  application_rejected
  comp_issued
  access_requested
  ticket_purchased
  plus_one_added
  referral_made
  enrichment_synced
  merged
  // Added 2026-07-03 (CRM substrate Phase 1 — consent floor). Each is added to the
  // DB via a standalone `ALTER TYPE ... ADD VALUE` (see prisma/sql/crm-consent-floor-enums.sql).
  channel_subscribed
  channel_unsubscribed
  suppression_added
  // Minimal RBAC (CRM substrate, Phase 1.5) — operator role change. Added to the
  // DB via a standalone ALTER TYPE ADD VALUE (prisma/sql/crm-rbac-enums.sql).
  role_changed
  // Phase 2A person spine - first-touch activity.
  account_created
  application_started
  // Ways-In Phase A (Stage 17) - added to the DB via a standalone
  // `ALTER TYPE ... ADD VALUE` (see prisma/sql/ways-in-phase-a.sql). No emitter
  // until the one-off-links phase (Phase C); the enum lands now so C needs no DDL.
  access_link_redeemed
  // Slice 3 (Communicate + log it) — emitted by POST /api/webhooks/resend when a
  // TransactionalEmailLog row has a known memberId/personId. Added to the DB via a
  // standalone `ALTER TYPE ... ADD VALUE` (see prisma/sql/comms-log-enums.sql).
  // newsletter_opened/sponsor_perk_clicked are pre-existing, unrelated values — left
  // untouched, not reused (they're unwired display-label-only values today).
  email_delivered

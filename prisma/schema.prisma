/// Slice 4 (Segments, saved views & the operator-action log) — substrate for
/// "remembers what the operator does" / attention-as-personalization. Distinct
/// from AuditEvent: AuditEvent is always single-target (one entityType+entityId);
/// an operator action may touch zero people (a query run), one (a one-off touch),
/// or many (a message sent, a list built) — see OperatorActionTarget below,
/// mirroring the Blast/BlastRecipient parent+child shape already in production.
/// `actionType` is free text, like AuditEvent.action, so new action types never
/// need a schema change. This slice wires exactly one write site: Segment
/// creation emits actionType 'list_built'. message_sent/query_run/one_off_touch
/// are named but NOT wired here — no real caller yet.
model OperatorAction {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  actorId     String
  actionType  String
  summary     String?
  metadata    Json?
  targetCount Int      @default(0)
  createdAt   DateTime @default(now())

  affected OperatorActionTarget[]

  @@index([workspaceId])
  @@index([workspaceId, actorId])
  @@index([workspaceId, actionType])
  @@index([createdAt])
}

/// Dual-pointer (personId/memberId), matching the pattern already used on
/// ChannelSubscription/SmsConversation/TransactionalEmailLog — so a future
/// recurrence-detection layer ("I text this one person happy birthday every
/// year") can cheaply query "every action that touched person X" by an indexed
/// column, not a Json id-array scan. That layer is NOT built this slice — this
/// is the seam, named not built.
model OperatorActionTarget {
  id        String         @id @default(cuid())
  actionId  String
  action    OperatorAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  personId  String?
  person    Person?        @relation(fields: [personId], references: [id], onDelete: SetNull)
  memberId  String?
  member    Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([actionId])
  @@index([personId])
  @@index([memberId])
}


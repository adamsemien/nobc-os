  invited
}

// ─────────────────────────────────────────────────────────────────────────────
// Digital Asset Manager (Stage 15) — operator media library + share surfaces.
// All assets live PRIVATE in R2; the app mints signed URLs at render time.
// ─────────────────────────────────────────────────────────────────────────────

enum AssetFileType {
  PHOTO
  VIDEO
}

enum MediaFolderType {
  FULL_GALLERY
  SELECTS
  VIDEO
  SPONSOR
  BRAND
}

enum ShareLinkMode {
  SPONSOR
  MEMBER_GALLERY
}

model Asset {
  id            String                      @id @default(cuid())
  workspaceId   String
  workspace     Workspace                   @relation(fields: [workspaceId], references: [id])
  filename      String
  url           String // R2 object key for the private full-res original
  thumbnailUrl  String // R2 object key for the 800px thumbnail
  blurhash      String?
  fileType      AssetFileType
  size          Int // bytes (per-asset; workspace total tracked as BigInt)
  width         Int?
  height        Int?
  duration      Float? // seconds, video only
  shootDate     DateTime? // EXIF DateTimeOriginal; default sort key, falls back to createdAt
  tags          String[]                    @default([]) // manual
  aiTags        String[]                    @default([]) // AI auto-tags (separate from manual)
  qualityScore  Float? // heuristic overall (Phase 1)
  qualityScores Json? // breakdown { sharpness, exposure, ... }
  energyLevel   String? // low | medium | high (inferred from scene labels)
  shooterCredit String? // photographer credit
  // Canto migration (Stage 0): provenance, content hash, and enriched media metadata.
  sourceSystem  String? // "canto" for migrated assets; null for in-app uploads
  sourceId      String? // source asset id (Canto asset id); idempotent re-import key
  sha256        String? // hex sha256 of the original bytes; exact-duplicate key
  exif          Json? // full EXIF / IPTC / XMP block (exiftool-vendored)
  dominantColor String? // hex, dominant swatch (node-vibrant)
  colorPalette  Json? // array of hex swatches (node-vibrant)
  /// CLIP image embedding, 768-dim (andreasjansson/clip-features). Written via raw
  /// SQL + pgvector since the typed client cannot write an Unsupported column; the
  /// HNSW cosine index is created out-of-band (not representable in schema.prisma).
  embedding     Unsupported("vector(768)")?
  /// Full-text search vector — maintained by the dam_asset_search_vector trigger
  /// (filename + tags + aiTags + sponsorName). GIN-indexed in prisma/sql/dam-search-vector.sql.
  searchVector  Unsupported("tsvector")?
  isSelect      Boolean                     @default(false)
  sortOrder     Int                         @default(0) // manual ordering
  folderId      String?
  folder        MediaFolder?                @relation(fields: [folderId], references: [id])
  eventId       String? // plain string + index, NO FK (mirrors Event.heroImageAssetId)
  sponsorName   String?
  uploadedBy    String // Clerk userId
  deletedAt     DateTime? // soft delete; null = live, set = trashed (30-day recover)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  downloads AssetDownload[]

  @@index([workspaceId])
  @@index([folderId])
  @@index([eventId])
  @@index([deletedAt])
  @@index([workspaceId, sha256])
}

model MediaFolder {
  id                String          @id @default(cuid())
  workspaceId       String
  workspace         Workspace       @relation(fields: [workspaceId], references: [id])
  name              String
  type              MediaFolderType
  eventId           String? // plain string + index, no FK
  parentId          String?
  parent            MediaFolder?    @relation("FolderTree", fields: [parentId], references: [id])
  children          MediaFolder[]   @relation("FolderTree")
  usageRightsExpiry DateTime?
  sortOrder         Int             @default(0)
  deletedAt         DateTime? // soft delete (folders)
  createdAt         DateTime        @default(now())

  assets     Asset[]
  shareLinks ShareLink[]

  @@index([workspaceId])
  @@index([eventId])
  @@index([parentId])
}

model ShareLink {
  id               String        @id @default(cuid())
  workspaceId      String
  workspace        Workspace     @relation(fields: [workspaceId], references: [id])
  token            String        @unique
  folderId         String
  folder           MediaFolder   @relation(fields: [folderId], references: [id])
  mode             ShareLinkMode
  password         String? // bcrypt hash, optional
  expiresAt        DateTime?
  firstAccessedAt  DateTime? // set on first access → triggers operator email
  lastAccessedAt   DateTime?
  accessCount      Int           @default(0)
  brandingOverride Json? // { logo, primaryColor, companyName }
  customDomain     String?       @unique
  watermark        Boolean       @default(false)
  allowedDownloads Int?
  createdAt        DateTime      @default(now())

  downloads AssetDownload[]

  @@index([workspaceId])
  @@index([folderId])
}

model AssetDownload {
  id           String     @id @default(cuid())
  workspaceId  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id])
  assetId      String
  asset        Asset      @relation(fields: [assetId], references: [id])
  shareLinkId  String?
  shareLink    ShareLink? @relation(fields: [shareLinkId], references: [id])
  downloadedAt DateTime   @default(now())

  @@index([workspaceId])
  @@index([assetId])
  @@index([shareLinkId])
}

// Stripe webhook idempotency ledger. Stripe delivers events at-least-once, so the
// webhook handler upserts on stripeId and short-circuits if the row already exists.
// Not user data: this is an infra ledger, so workspaceId is best-effort (nullable).
model StripeEvent {
  id          String   @id @default(cuid())
  stripeId    String   @unique // Stripe event id (evt_...), the dedup key
  type        String // event.type, e.g. "payment_intent.succeeded"
  workspaceId String? // resolved from PaymentIntent metadata when present; null for account-level events
  processedAt DateTime @default(now())

  @@index([type])
  @@index([processedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Instagram Story Automation (New Feature)
// ─────────────────────────────────────────────────────────────────────────────

enum StoryStatus {
  DRAFT // Story generated, not yet scheduled
  QUEUED // Scheduled, pending publishing
  PUBLISHED // Successfully posted to Instagram
  FAILED // Publication attempt failed
  CANCELLED // Operator cancelled the story
}

model InstagramStory {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  eventId       String? // Associated event (optional)
  sourceAssetId String? // Original DAM asset ID

  // Story metadata
  status     StoryStatus @default(DRAFT)
  title      String? // Event name or story name
  dayCounter Int? // Day 1, Day 2, etc. (optional)

  // Generated story
  storyImageUrl String? // R2 signed URL for the generated 1080x1920 PNG
  storyR2Key    String? // R2 object key (for expiry/presign refresh)

  // Instagram metadata
  instagramMediaId String? // The actual Instagram post ID after publishing
  scheduledAt      DateTime? // When it should be posted
  publishedAt      DateTime? // When it was actually posted

  // Workflow tracking
  createdBy String // Clerk userId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Retry tracking for failed stories

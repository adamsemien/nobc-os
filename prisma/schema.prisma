generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (Prisma 7 no longer accepts `url`/`directUrl`
  // here): `url` = pooled DATABASE_URL (PgBouncer), `directUrl` = unpooled DIRECT_URL that
  // `prisma migrate` / `migrate resolve` uses so DDL runs off the pooler. See .env.local.example.
}

model Workspace {
  id         String   @id @default(cuid())
  clerkOrgId String   @unique
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // White-label / workspace settings
  logoUrl           String?
  primaryColor      String?
  contactEmail      String?
  tierCharterName   String  @default("Charter")
  tierStandardName  String  @default("Standard")
  tierWaitlistName  String  @default("Waitlist")
  defaultTemplateId String?

  members                Member[]
  applications           Application[]
  events                 Event[]
  eventSeries            EventSeries[]
  rsvps                  RSVP[]
  orders                 Order[]
  tickets                Ticket[]
  payments               Payment[]
  waitlistEntries        WaitlistEntry[]
  auditEvents            AuditEvent[]
  redList                RedList[]
  eventFlowTemplates     EventFlowTemplate[]
  questionDefinitions    QuestionDefinition[]
  applicationTemplates   ApplicationTemplate[]
  intelligenceInsights   IntelligenceInsight[]
  savedReports           SavedReport[]
  agentConversations     AgentConversation[]
  ticketTiers            TicketTier[]
  accessTokens           AccessToken[]
  promoCodes             PromoCode[]
  tags                   Tag[]
  entityTags             EntityTag[]
  sponsorBrandProfiles   SponsorBrandProfile[]
  generatedAssets        GeneratedAsset[]
  recapSnapshots         RecapSnapshot[]
  surveyResponses        SurveyResponse[]
  svixAppId              String?
  watchList              WatchList[]
  emailTemplates         EmailTemplate[]
  platformSettings       PlatformSetting[]
  eventWorkflows         EventWorkflow[]
  operatorComments       OperatorComment[]
  operatorNotifications  OperatorNotification[]
  qaMissions             QAMission[]
  membershipTiers        MembershipTier[]
  smsConversations       SmsConversation[]
  workspaceMembers       WorkspaceMember[]
  memberEngagementEvents MemberEngagementEvent[]
  contactSources         ContactSource[]
  transactionalEmailLogs TransactionalEmailLog[]

  // Slice 4 (Segments, saved views & the operator-action log). Relation fields
  // only; no columns on Workspace.
  segments        Segment[]
  operatorActions OperatorAction[]

  // Digital Asset Manager (Stage 15)
  assets         Asset[]
  mediaFolders   MediaFolder[]
  shareLinks     ShareLink[]
  assetDownloads AssetDownload[]

  // Instagram Story Automation
  instagramStories      InstagramStory[]
  instagramStoryBatches InstagramStoryBatch[]

  // Access Gate Engine v3 - M1 (Stage 17)
  gates        Gate[]
  gateNodes    GateNode[]
  gateProofs   GateProof[]
  growthEdges  GrowthEdge[]
  gateSessions GateSession[]

  // Attendee messaging layer (Stage 18)
  blasts             Blast[]
  suppressedContacts SuppressedContact[]

  // Consent floor (CRM substrate, Phase 1) — the channel-consent axis. Relation
  // fields only; no columns on Workspace.
  channelSubscriptions ChannelSubscription[]
  suppressionEntries   SuppressionEntry[]

  // Person-centric CRM spine (Phase 2A)
  persons             Person[]
  organizations       Organization[]
  personOrganizations PersonOrganization[]

  // Operator-selected Claude model for AI features.
  // Display preference + server fallback. CLAUDE.md still locks the application-scoring
  // call to claude-sonnet-4-20250514; this column gates agent/chat surfaces.
  aiModel String?

  // Editable tier labels for the 0-100 score. null = use defaults (Resident/Member/Considering).
  // Shape: { top: string, mid: string, low: string }.
  tierNames Json?

  // DAM total stored bytes; +on upload, -on permanent delete (Stage 15)
  storageBytes BigInt @default(0)

  eventAccessModels EventAccessModel[]
}

/// Operator role within a workspace. Hierarchy: ADMIN > STAFF > READ_ONLY.
enum OperatorRole {
  // Minimal RBAC (CRM substrate, Phase 1.5). Hierarchy OWNER > ADMIN > STAFF >
  // READ_ONLY, enforced in code (lib/operator-role.ts RANK + lib/auth/can.ts).
  // READ_ONLY is the read tier, displayed "Viewer" in the UI. OWNER is additive;
  // existing ADMIN operators are backfilled to OWNER so nobody loses access on
  // deploy (see prisma/sql/crm-rbac-backfill.sql).
  OWNER
  ADMIN
  STAFF
  READ_ONLY
}

/// A person with operator access to a workspace. Operators are Clerk org
/// members; this row carries their role (and supports email invites that
/// have no clerkUserId yet — V2 sends the email, for now we just store it).
model WorkspaceMember {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clerkUserId String?
  email       String
  firstName   String?
  lastName    String?
  role        OperatorRole @default(STAFF)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([clerkUserId])
}

model EmailTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  key         String
  name        String
  description String?
  subject     String
  bodyHtml    String    @db.Text
  bodyText    String    @db.Text
  variables   Json
  enabled     Boolean   @default(true)
  updatedAt   DateTime  @updatedAt
  updatedBy   String?

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model PlatformSetting {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  key         String
  value       String
  type        String
  description String?
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  GUEST
}

/// CRM contact roles — multi-valued and ORTHOGONAL to the MemberStatus lifecycle.
/// A person can hold several at once (e.g. member + subscriber + sponsor_contact).
/// "Member"/"Guest" are also derivable from status; the explicit roles cover the
/// relationships status can't express. See
/// _context/16-member-intelligence/crm-spine/CRM-TERMINOLOGY-AND-ROLES.md.
enum ContactRole {
  member
  guest
  subscriber
  lead
  vendor
  sponsor_contact
}

/// Which system a contact (or one of their identities) came from. Drives the
/// ContactSource provenance rows + the connector ingestion pipeline.
enum ContactSourceSystem {
  operator
  beehiiv
  activecampaign
  producer
  csv
  tenur
  clerk
  application
  event
}

/// CRM provenance — one row per (member, source) system a person appears in.
/// The ingestion pipeline writes these during identity resolution; the merge-review
/// UI reads rawSnapshot to resolve cross-source conflicts. Workspace-scoped.
model ContactSource {
  id           String              @id @default(cuid())
  workspaceId  String
  workspace    Workspace           @relation(fields: [workspaceId], references: [id])
  // Phase 2A: provenance now hangs off Person; memberId kept for back-compat reads.
  memberId     String?
  member       Member?             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  personId     String?
  person       Person?             @relation(fields: [personId], references: [id], onDelete: Cascade)
  source       ContactSourceSystem
  /// Stable id of this person in the source system (email / opaque id) — the key
  /// the ingestion match chain dedupes on.
  externalId   String?
  /// active | conflict | merged — set by the ingestion pipeline.
  syncStatus   String              @default("active")
  /// Full source record at last sync (powers the merge-review UI).
  rawSnapshot  Json?
  firstSeenAt  DateTime            @default(now())
  lastSyncedAt DateTime            @default(now())

  @@unique([workspaceId, memberId, source])
  @@unique([workspaceId, personId, source])
  @@index([workspaceId])
  @@index([workspaceId, source, externalId])
  @@index([memberId])
  @@index([personId])
}

/// Person-centric CRM spine (Phase 2A). Universal base record: every human the
/// platform touches is a Person from first contact - applicants who never
/// submit, guests, sponsor staff, SaaS prospects, members. Identity fields are
/// nullable (an SMS-only contact has only a phone). Membership is a profile ON
/// a Person (Member.personId). Psychographics stay in MemberPsychographics on
/// the Member side of the sponsor firewall and NEVER move here. Rows are minted
/// only via resolvePerson() (lib/crm/resolve-person.ts) - no parallel minting.
model Person {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  clerkUserId String?
  /// emailVerified=true only when the address was proven by an identity
  /// provider (Clerk verified email). Typed-in emails (application forms,
  /// operator entry) stay false. An UNVERIFIED email NEVER links to an
  /// existing Person at resolve time - resolvePerson mints a new Person and
  /// flags the pair via potentialDuplicateOfId. (workspaceId, email) is
  /// therefore deliberately NON-unique: email duplicates are legitimate
  /// until the 2B merge queue resolves them.
  email         String?
  emailVerified Boolean @default(false)
  phone         String?
  firstName     String?
  lastName      String?

  /// Multi-valued CRM roles - same vocabulary as Member.roles.
  roles ContactRole[] @default([])

  /// 2B merge-queue flag: set when this Person was minted with an unverified
  /// email matching an existing Person. Cleared on merge or dismiss.
  potentialDuplicateOfId String?
  potentialDuplicateOf   Person?  @relation("PersonPotentialDuplicate", fields: [potentialDuplicateOfId], references: [id])
  potentialDuplicates    Person[] @relation("PersonPotentialDuplicate")

  // Soft-merge: a duplicate person points at its canonical record (mirrors Member merge).
  mergedIntoId String?
  mergedAt     DateTime?
  mergedInto   Person?   @relation("PersonMerge", fields: [mergedIntoId], references: [id])
  mergedFrom   Person[]  @relation("PersonMerge")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Slice 0: CRM spine generalization. Mirrors Member.customFields/fieldProvenance
  // exactly - keyed by FieldDefinition.stableKey. FieldDefinition rows stay scoped to
  // section: 'member' for this slice (shared catalog with Member, accepted debt - see
  // _context/_audit for a possible future split into a 'person' section).
  customFields    Json?
  fieldProvenance Json?

  members              Member[]
  applications         Application[]
  contactSources       ContactSource[]
  engagementEvents     MemberEngagementEvent[]
  rsvps                RSVP[]
  organizations        PersonOrganization[]
  channelSubscriptions ChannelSubscription[]
  suppressionEntries   SuppressionEntry[]
  smsConversations     SmsConversation[]
  transactionalEmailLogs TransactionalEmailLog[]

  // Slice 4 (Segments, saved views & the operator-action log). Relation fields
  // only; no columns on Person.
  segmentSnapshotMembers SegmentSnapshotMember[]
  operatorActionTargets  OperatorActionTarget[]

  // clerkUserId stays unique when present (NULLs are distinct in Postgres).
  // email is a plain index - see emailVerified doc above.
  @@unique([workspaceId, clerkUserId])
  @@index([workspaceId, email])
  @@index([workspaceId])
  @@index([workspaceId, phone])
  @@index([mergedIntoId])
  @@index([potentialDuplicateOfId])
}

enum OrganizationKind {
  sponsor
  saas_prospect
  member_company
  vendor
  other
}

/// First-class account record (Phase 2A): sponsor accounts, SaaS prospects,
/// members' companies. Deal (Phase 2B) will hang off this - nothing here blocks it.
model Organization {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  name        String
  domain      String?
  kind        OrganizationKind @default(other)
  website     String?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  people PersonOrganization[]

  @@unique([workspaceId, domain])
  @@index([workspaceId])
}

/// Person <-> Organization affiliation. Sponsor staff are Persons affiliated to
/// a sponsor Organization; sponsor-facing surfaces still read ONLY the
/// sponsor_audience_member view - never Person or this table.
model PersonOrganization {
  id             String       @id @default(cuid())
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id])
  personId       String
  person         Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String?
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([personId, organizationId])
  @@index([workspaceId])
  @@index([organizationId])
}

model Member {
  id                    String        @id @default(cuid())
  workspaceId           String
  workspace             Workspace     @relation(fields: [workspaceId], references: [id])
  clerkUserId           String
  email                 String
  firstName             String
  lastName              String
  phone                 String?
  // Person spine (Phase 2A): Member is the membership profile ON a Person.
  // Nullable + additive - backfill links existing rows.
  personId              String?
  /// Checkout consent capture (Event Builder Rebuild, Phase F - ADD 1).
  /// Three separate signals, never bundled, never pre-checked; affirmative
  /// consent only ever sets them true (+ timestamp). Mirrors the apply
  /// flow's structured consent model on Application. Gates marketing
  /// contact, never the ticket.
  marketingEmailOptIn   Boolean       @default(false)
  marketingEmailOptInAt DateTime?
  marketingSmsOptIn     Boolean       @default(false)
  marketingSmsOptInAt   DateTime?
  status                MemberStatus  @default(PENDING)
  tags                  String[]
  /// Multi-valued CRM roles. Orthogonal to `status` (the membership lifecycle) —
  /// a person can be e.g. member + subscriber + sponsor_contact at once. Additive;
  /// default empty so existing rows are unaffected.
  roles                 ContactRole[] @default([])
  energyScore           Int?
  networkValueScore     Int?
  aiSummary             String?
  redListed             Boolean       @default(false)
  approved              Boolean       @default(false)
  approvedAt            DateTime?
  memberQrCode          String?       @unique
  walletPassId          String?
  passIssuedAt          DateTime?
  totalEventsAttended   Int           @default(0)
  lastAttendedDate      DateTime?

  // Referral linkage + network-effect scoring
  referredByMemberId  String?
  networkCapitalScore Float?

  // Soft-merge (member-intelligence PR1): a duplicate person points at its
  // canonical record; reads resolve through it, history re-points to canonical.
  // Nullable + additive — no row deletion.
  mergedIntoId String?
  mergedAt     DateTime?

  // Sponsor intelligence — self-reported / enriched demographic + firmographic fields
  industry        String?
  jobFunction     String?
  seniority       String?
  companySize     String?
  ageRange        String?
  householdIncome String?

  // PR2 — member-intelligence dimensions. Firmographic/demographic values live in
  // customFields (keyed by FieldDefinition.stableKey); fieldProvenance carries the
  // per-field { value, source, confidence, syncedAt } record. Psychographic data is
  // deliberately NOT here — it lives in the separate MemberPsychographics table so
  // the sponsor view physically cannot reach it.
  customFields         Json?
  fieldProvenance      Json?
  city                 String?
  country              String?
  companyName          String?
  companyDomain        String?
  linkedinUrl          String?
  instagram            String?
  enrichmentStatus     MemberEnrichmentStatus @default(NONE)
  enrichmentLastSynced DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Set when a real Clerk userId is first claimed from a placeholder. Additive — Adam runs
  // prisma/sql/add-member-claimed-at.sql before this field is in production.
  claimedAt DateTime?

  rsvps           RSVP[]
  tickets         Ticket[]
  waitlistEntries WaitlistEntry[]

  // Self-relation: who referred this member, and who they referred.
  referredByMember Member?                 @relation("MemberReferrals", fields: [referredByMemberId], references: [id])
  referredMembers  Member[]                @relation("MemberReferrals")
  engagementEvents MemberEngagementEvent[]
  surveyResponses  SurveyResponse[]

  // Self-relation: soft-merge canonical pointer.
  mergedInto Member?  @relation("MemberMerge", fields: [mergedIntoId], references: [id])
  mergedFrom Member[] @relation("MemberMerge")

  // Psychographic data — separate table, firewalled from sponsor surfaces.
  psychographics MemberPsychographics?

  // Person spine (Phase 2A)
  person Person? @relation(fields: [personId], references: [id])

  // CRM provenance — which source systems this person came from.
  contactSources ContactSource[]

  // Access Gate Engine v3 - M1 (Stage 17)
  gateProofs      GateProof[]
  gateSessions    GateSession[]
  growthEdgesFrom GrowthEdge[]  @relation("GrowthEdgeFrom")
  growthEdgesTo   GrowthEdge[]  @relation("GrowthEdgeTo")

  // Consent floor (CRM substrate, Phase 1). Relation fields only; no columns on Member.
  channelSubscriptions ChannelSubscription[]
  suppressionEntries   SuppressionEntry[]

  // Slice 3 (Communicate + log it). Relation fields only; no columns on Member.
  smsConversations       SmsConversation[]
  transactionalEmailLogs TransactionalEmailLog[]

  // Slice 4 (Segments, saved views & the operator-action log). Relation fields
  // only; no columns on Member.
  segmentSnapshotMembers SegmentSnapshotMember[]
  operatorActionTargets  OperatorActionTarget[]

  @@unique([workspaceId, clerkUserId])
  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([referredByMemberId])
  @@index([mergedIntoId])
  @@index([workspaceId, phone])
  @@index([personId])
}

enum MemberEnrichmentStatus {
  NONE
  PENDING
  PARTIAL
  COMPLETE
  STALE
}

/// Psychographic profile — INTERNAL/operator-only. Held in its own table so the
/// sponsor_audience_member view (and any sponsor-facing query) physically cannot
/// join it. Populated additively from Application.archetype* (no change to
/// config/archetypes.ts or the scoring system).
model MemberPsychographics {
  id              String   @id @default(cuid())
  workspaceId     String
  memberId        String   @unique
  member          Member   @relation(fields: [memberId], references: [id])
  archetype       String?
  archetypeScores Json?
  interests       String[]
  tasteSignals    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workspaceId])
}

/// Operator-defined firmographic/demographic fields (workspace-scoped). Mirrors
/// the QuestionDefinition pattern. `sponsorVisible` gates whether a field may
/// appear in sponsor-facing aggregates.
model FieldDefinition {
  id             String   @id @default(cuid())
  workspaceId    String
  stableKey      String
  name           String
  type           String
  section        String
  sponsorVisible Boolean  @default(false)
  options        String[]
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([workspaceId, stableKey])
  @@index([workspaceId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  HOLD
  WAITLISTED
  DECLINED
}

enum AiApplicationRecommendation {
  strong_yes
  yes
  unclear
  no
  strong_no
}

model Application {
  id                      String                       @id @default(cuid())
  workspaceId             String
  workspace               Workspace                    @relation(fields: [workspaceId], references: [id])
  memberId                String?
  // Real Clerk user id once the applicant creates/links an account. Nullable +
  // additive: pre-account (cookie) drafts and all existing rows stay null.
  // Enables cross-device, account-based resume.
  clerkUserId             String?
  email                   String
  fullName                String
  // Person spine (Phase 2A): the human behind this application, minted at application start.
  personId                String?
  person                  Person?                      @relation(fields: [personId], references: [id])
  phone                   String?
  city                    String?
  neighborhood            String?
  referredBy              String?
  consentEmail            Boolean                      @default(false)
  consentSms              Boolean                      @default(false)
  // --- Phase A: structured consent + lifecycle (additive; legacy consentEmail/consentSms above are unchanged) ---
  agreedToMembershipTerms Boolean                      @default(false)
  termsAcceptedAt         DateTime?
  termsVersion            String?
  emailOptIn              Boolean                      @default(false)
  emailOptInAt            DateTime?
  smsOptInAt              DateTime?
  consentIp               String?
  consentUserAgent        String?
  archivedAt              DateTime?
  status                  ApplicationStatus            @default(PENDING)
  reviewedAt              DateTime?
  reviewedBy              String?
  reviewNote              String?
  rejectionReason         String?
  aiTags                  String[]
  aiScore                 Float?
  aiRecommendation        AiApplicationRecommendation?
  aiReasoning             String?
  duplicateFlag           Boolean                      @default(false)
  archetype               String?
  archetypeScores         Json?
  personalizedCopy        String?
  // Reveal "Why we called you this" note (six-archetype recut, 2026-07). Written
  // fresh for new applications; legacy rows keep personalizedCopy. Additive-only.
  personalNote            String?
  // Apply Scoring v2 — Reveal B persisted tally output (additive, 2026-07-07). The
  // deterministic tally decides these at scoring time; the reveal reads them
  // VERBATIM and never recomputes the blend from the normalized archetypeScores
  // (that normalized vector is fit-centered and flattens the top-two to ~55/45).
  // The primary nature is the existing `archetype` column above.
  revealSecondary         String? // secondary nature (STORED enum; map to displayName in UI)
  revealBlendPrimary      Int? // decisive blend %, primary (from raw combined points)
  revealBlendSecondary    Int? // decisive blend %, secondary
  revealOpenerPhrase      String? // Q6 (bestSelf) openerPhrase — opens the reveal, never contradicted
  revealHabitatThrive     String? // Q4 (perfectFriday) picked option label — "your best rooms"
  revealHabitatDim        String? // Q5 (skipFriday) picked option label — "rooms that don't deserve you"
  templateId              String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  answers  ApplicationAnswer[]
  template ApplicationTemplate? @relation(fields: [templateId], references: [id])
  backup   ApplicationBackup?

  @@index([workspaceId])
  @@index([templateId])
  @@index([clerkUserId])
  @@index([personId])
}

model ApplicationAnswer {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  questionKey   String
  answer        String
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

enum BackupStatus {
  PENDING
  DONE
  FAILED
}

/// Durable off-platform backup of a single membership application (the company's
/// most critical data asset). One row per application; the write-through hook on
/// submit and the hourly reconciliation cron both drive it toward DONE. The actual
/// JSON document + photo live in the external destination (Google Drive); this row
/// is the local ledger of backup state. Workspace-scoped like every user-data table.
model ApplicationBackup {
  id            String       @id @default(cuid())
  workspaceId   String
  applicationId String       @unique
  application   Application? @relation(fields: [applicationId], references: [id])
  status        BackupStatus @default(PENDING)
  destination   String       @default("google_drive")
  /// Drive file id of the uploaded JSON document.
  externalId    String?
  /// sha256 of the serialized JSON payload, for integrity verification.
  checksum      String?
  attempts      Int          @default(0)
  lastError     String?
  backedUpAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workspaceId])
  @@index([status])
}

enum EventAccessMode {
  OPEN
  TICKETED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum EventVisibility {
  public
  members_only
  unlisted
}

enum ServiceFeeMode {
  absorb
  pass_stripe_only
  pass_stripe_plus_markup
  flat_per_ticket
}

enum RefundPolicy {
  none
  window
  credit
}

enum WaitlistPromotion {
  none
  same_tier_only
  next_tier_current_price
  next_tier_held_price
}

model Event {
  id                    String          @id @default(cuid())
  workspaceId           String
  workspace             Workspace       @relation(fields: [workspaceId], references: [id])
  slug                  String
  title                 String
  description           String?
  /// Full public hero image URL (e.g. Vercel Blob). Used directly as img src.
  heroImageAssetId      String?
  startAt               DateTime
  endAt                 DateTime?
  location              String?
  /// Optional deep link (Google Maps, Apple Maps, etc.).
  mapsUrl               String?
  capacity              Int?
  accessMode            EventAccessMode @default(OPEN)
  approvalRequired      Boolean         @default(false)
  plusOnesAllowed       Boolean         @default(false)
  status                EventStatus     @default(DRAFT)
  showCapacity          Boolean         @default(false)
  priceInCents          Int?
  nonMemberPriceInCents Int?
  refundWindowHours     Int?
  runOfShow             String?         @db.Text
  template              String          @default("editorial")
  /// Per-event member-page styling overrides (scrim, title scale, hero height,
  /// texture, card/footer). Validated by lib/page-style.ts; null = brand defaults.
  pageStyle             Json?
  eventAccess           Json            @default("{\"member\":{\"enabled\":true,\"gate\":\"auto_confirm\",\"priceCents\":0},\"guest\":{\"enabled\":false,\"gate\":\"pay\",\"priceCents\":0},\"comp\":{\"enabled\":false,\"budgetCap\":null}}")

  // Recurring — seriesId links to EventSeries
  seriesId       String?
  instanceNumber Int?
  recurrenceRule String?
  series         EventSeries? @relation(fields: [seriesId], references: [id])

  // Visibility & calendar
  visibility  EventVisibility @default(public)
  publishesAt DateTime?
  featured    Boolean         @default(false)

  // Group buy
  groupBuyEnabled                 Boolean @default(true)
  requireAttendeeDetailsPerTicket Boolean @default(false)

  // Service fees
  serviceFeeMode       ServiceFeeMode @default(absorb)
  serviceFeePercentBps Int?
  serviceFeeFlatCents  Int?


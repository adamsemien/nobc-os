generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id         String   @id @default(cuid())
  clerkOrgId String   @unique
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members         Member[]
  applications    Application[]
  events          Event[]
  rsvps           RSVP[]
  tickets         Ticket[]
  payments        Payment[]
  waitlistEntries WaitlistEntry[]
  auditEvents     AuditEvent[]
  redList              RedList[]
  eventFlowTemplates   EventFlowTemplate[]
  svixAppId       String?
}

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  GUEST
}

model Member {
  id                String       @id @default(cuid())
  workspaceId       String
  workspace         Workspace    @relation(fields: [workspaceId], references: [id])
  clerkUserId       String
  email             String
  firstName         String
  lastName          String
  phone             String?
  status            MemberStatus @default(PENDING)
  tags              String[]
  energyScore       Int?
  networkValueScore Int?
  aiSummary         String?
  redListed         Boolean      @default(false)
  approved          Boolean      @default(false)
  approvedAt        DateTime?
  memberQrCode      String?      @unique
  walletPassId      String?
  passIssuedAt      DateTime?
  totalEventsAttended Int        @default(0)
  lastAttendedDate  DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  rsvps           RSVP[]
  tickets         Ticket[]
  waitlistEntries WaitlistEntry[]

  @@unique([workspaceId, clerkUserId])
  @@unique([workspaceId, email])
  @@index([workspaceId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  HOLD
}

enum AiApplicationRecommendation {
  strong_yes
  yes
  unclear
  no
  strong_no
}

model Application {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  memberId    String?
  email       String
  fullName    String
  phone        String?
  city         String?
  referredBy   String?
  consentEmail Boolean           @default(false)
  consentSms   Boolean           @default(false)
  status       ApplicationStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewedBy  String?
  rejectionReason String?
  aiTags      String[]
  aiScore          Float?
  aiRecommendation AiApplicationRecommendation?
  aiReasoning      String?
  duplicateFlag    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  answers ApplicationAnswer[]

  @@index([workspaceId])
}

model ApplicationAnswer {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  questionKey   String
  answer        String
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

enum EventAccessMode {
  OPEN
  TICKETED
  APPLY_OR_PAY
}

/// Sub-mode when accessMode is APPLY_OR_PAY (non-member / hybrid flows).
enum EventApplyMode {
  APPROVAL_HOLDS_TICKET
  SUBMIT_CONFIRMS_ENTRY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

model Event {
  id               String          @id @default(cuid())
  workspaceId      String
  workspace        Workspace       @relation(fields: [workspaceId], references: [id])
  slug             String
  title            String
  description      String?
  /// R2 object key or asset id used to build a presigned GET URL for hero imagery.
  heroImageAssetId      String?
  startAt          DateTime
  endAt            DateTime?
  location         String?
  /// Optional deep link (Google Maps, Apple Maps, etc.).
  mapsUrl               String?
  capacity         Int?
  accessMode            EventAccessMode @default(OPEN)
  applyMode             EventApplyMode?
  approvalRequired      Boolean         @default(false)
  plusOnesAllowed       Boolean         @default(false)
  status                EventStatus     @default(DRAFT)
  showCapacity          Boolean         @default(false)
  priceInCents          Int?
  nonMemberPriceInCents Int?
  refundWindowHours     Int?
  runOfShow             String?         @db.Text
  template              String          @default("editorial")
  eventAccess           Json            @default("{\"member\":{\"enabled\":true,\"gate\":\"auto_confirm\",\"priceCents\":0},\"guest\":{\"enabled\":false,\"gate\":\"pay\",\"priceCents\":0},\"comp\":{\"enabled\":false,\"budgetCap\":null}}")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  customQuestions EventCustomQuestion[]
  rsvps           RSVP[]
  tickets         Ticket[]
  waitlistEntries WaitlistEntry[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

enum FieldType {
  TEXT
  TEXTAREA
  SELECT
  MULTISELECT
  CHECKBOX
  DATE
  EMAIL
  PHONE
}

enum QuestionFlowStep {
  BEFORE_SUBMIT
  AFTER_PAYMENT
  BEFORE_APPROVAL
}

model EventCustomQuestion {
  id           String           @id @default(cuid())
  eventId      String
  event        Event            @relation(fields: [eventId], references: [id])
  workspaceId  String
  label        String
  fieldType    FieldType
  options      String[]
  required     Boolean          @default(false)
  order        Int
  showToMember Boolean          @default(true)
  showToGuest  Boolean          @default(true)
  whenInFlow   QuestionFlowStep @default(BEFORE_SUBMIT)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([workspaceId])
  @@index([eventId])
}

enum RSVPStatus {
  CONFIRMED
  DECLINED
  WAITLISTED
}

model RSVP {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  eventId     String
  event       Event      @relation(fields: [eventId], references: [id])
  memberId    String
  member      Member     @relation(fields: [memberId], references: [id])
  status             RSVPStatus @default(CONFIRMED)
  ticketStatus       String     @default("confirmed")
  origin             String     @default("direct")
  plusOneOfMemberId  String?
  customAnswers      Json?
  checkedIn          Boolean    @default(false)
  checkedInAt        DateTime?
  stripePaymentIntentId String?
  refundedAt         DateTime?
  refundAmountCents  Int?
  isComp             Boolean    @default(false)
  compType           String?
  guestEmail         String?
  guestName          String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  tickets Ticket[]

  @@unique([workspaceId, eventId, memberId])
  @@index([workspaceId])
  @@index([eventId])
}

enum TicketStatus {
  AUTHORIZED
  CAPTURED
  REFUNDED
  CANCELLED
}

model Ticket {
  id                    String       @id @default(cuid())
  workspaceId           String
  workspace             Workspace    @relation(fields: [workspaceId], references: [id])
  eventId               String
  event                 Event        @relation(fields: [eventId], references: [id])
  memberId              String
  member                Member       @relation(fields: [memberId], references: [id])
  rsvpId                String
  rsvp                  RSVP         @relation(fields: [rsvpId], references: [id])
  stripePaymentIntentId String?
  amount                Int
  currency              String
  status                TicketStatus
  walletPassId          String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  payments Payment[]

  @@index([workspaceId])
  @@index([eventId])
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

model Payment {
  id                    String        @id @default(cuid())
  workspaceId           String
  workspace             Workspace     @relation(fields: [workspaceId], references: [id])
  ticketId              String
  ticket                Ticket        @relation(fields: [ticketId], references: [id])
  stripePaymentIntentId String
  amount                Int
  currency              String
  status                PaymentStatus
  capturedAt            DateTime?
  refundedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([workspaceId])
  @@index([ticketId])
}

model WaitlistEntry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id])
  memberId    String?
  member      Member?   @relation(fields: [memberId], references: [id])
  email       String
  name        String
  position    Int
  notifiedAt  DateTime?
  claimedAt   DateTime?
  expiresAt   DateTime?
  promotedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([eventId])
}

model AuditEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  actorId     String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([entityType, entityId])
}

model RedList {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  email           String?
  namePattern     String?
  reason          String?
  addedByPersonId String?
  createdAt       DateTime  @default(now())

  @@index([workspaceId])
  @@index([email])
}

model EventFlowTemplate {
  id                    String    @id @default(cuid())
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  name                  String
  accessMode            String
  applyMode             String?
  priceInCents          Int?
  nonMemberPriceInCents Int?
  approvalRequired      Boolean   @default(false)
  plusOnesAllowed       Boolean   @default(false)
  showCapacity          Boolean   @default(false)
  customQuestions       Json      @default("[]")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([workspaceId])
}

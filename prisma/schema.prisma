generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id         String   @id @default(cuid())
  clerkOrgId String   @unique
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // White-label / workspace settings
  logoUrl           String?
  primaryColor      String?
  contactEmail      String?
  tierCharterName   String  @default("Charter")
  tierStandardName  String  @default("Standard")
  tierWaitlistName  String  @default("Waitlist")
  defaultTemplateId String?

  members              Member[]
  applications         Application[]
  events               Event[]
  eventSeries          EventSeries[]
  rsvps                RSVP[]
  orders               Order[]
  tickets              Ticket[]
  payments             Payment[]
  waitlistEntries      WaitlistEntry[]
  auditEvents          AuditEvent[]
  redList              RedList[]
  eventFlowTemplates   EventFlowTemplate[]
  questionDefinitions  QuestionDefinition[]
  applicationTemplates ApplicationTemplate[]
  intelligenceInsights IntelligenceInsight[]
  savedReports         SavedReport[]
  agentConversations   AgentConversation[]
  ticketTiers          TicketTier[]
  accessTokens         AccessToken[]
  promoCodes           PromoCode[]
  tags                 Tag[]
  entityTags           EntityTag[]
  sponsorBrandProfiles SponsorBrandProfile[]
  generatedAssets      GeneratedAsset[]
  svixAppId            String?
  watchList            WatchList[]
  emailTemplates       EmailTemplate[]
  platformSettings     PlatformSetting[]
  eventWorkflows       EventWorkflow[]
  operatorComments     OperatorComment[]
  operatorNotifications OperatorNotification[]
  qaMissions           QAMission[]
  membershipTiers      MembershipTier[]
  smsConversations     SmsConversation[]
  workspaceMembers     WorkspaceMember[]
  memberEngagementEvents MemberEngagementEvent[]

  // Digital Asset Manager (Stage 15)
  assets         Asset[]
  mediaFolders   MediaFolder[]
  shareLinks     ShareLink[]
  assetDownloads AssetDownload[]

  // Operator-selected Claude model for AI features.
  // Display preference + server fallback. CLAUDE.md still locks the application-scoring
  // call to claude-sonnet-4-20250514; this column gates agent/chat surfaces.
  aiModel              String?

  // Editable tier labels for the 0-100 score. null = use defaults (Resident/Member/Considering).
  // Shape: { top: string, mid: string, low: string }.
  tierNames            Json?

  // DAM total stored bytes; +on upload, -on permanent delete (Stage 15)
  storageBytes         BigInt   @default(0)
}

/// Operator role within a workspace. Hierarchy: ADMIN > STAFF > READ_ONLY.
enum OperatorRole {
  ADMIN
  STAFF
  READ_ONLY
}

/// A person with operator access to a workspace. Operators are Clerk org
/// members; this row carries their role (and supports email invites that
/// have no clerkUserId yet — V2 sends the email, for now we just store it).
model WorkspaceMember {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clerkUserId String?
  email       String
  firstName   String?
  lastName    String?
  role        OperatorRole @default(STAFF)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([clerkUserId])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  key         String
  name        String
  description String?
  subject     String
  bodyHtml    String   @db.Text
  bodyText    String   @db.Text
  variables   Json
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model PlatformSetting {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  key         String
  value       String
  type        String
  description String?
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  GUEST
}

model Member {
  id                String       @id @default(cuid())
  workspaceId       String
  workspace         Workspace    @relation(fields: [workspaceId], references: [id])
  clerkUserId       String
  email             String
  firstName         String
  lastName          String
  phone             String?
  status            MemberStatus @default(PENDING)
  tags              String[]
  energyScore       Int?
  networkValueScore Int?
  aiSummary         String?
  redListed         Boolean      @default(false)
  approved          Boolean      @default(false)
  approvedAt        DateTime?
  memberQrCode      String?      @unique
  walletPassId      String?
  passIssuedAt      DateTime?
  totalEventsAttended Int        @default(0)
  lastAttendedDate  DateTime?

  // Referral linkage + network-effect scoring
  referredByMemberId  String?
  networkCapitalScore Float?

  // Sponsor intelligence — self-reported / enriched demographic + firmographic fields
  industry          String?
  jobFunction       String?
  seniority         String?
  companySize       String?
  ageRange          String?
  householdIncome   String?

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  rsvps           RSVP[]
  tickets         Ticket[]
  waitlistEntries WaitlistEntry[]

  // Self-relation: who referred this member, and who they referred.
  referredByMember Member?  @relation("MemberReferrals", fields: [referredByMemberId], references: [id])
  referredMembers  Member[] @relation("MemberReferrals")
  engagementEvents MemberEngagementEvent[]

  @@unique([workspaceId, clerkUserId])
  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([referredByMemberId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  HOLD
  WAITLISTED
  DECLINED
}

enum AiApplicationRecommendation {
  strong_yes
  yes
  unclear
  no
  strong_no
}

model Application {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  memberId    String?
  email       String
  fullName    String
  phone        String?
  city         String?
  neighborhood String?
  referredBy   String?
  consentEmail Boolean           @default(false)
  consentSms   Boolean           @default(false)
  status       ApplicationStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewNote  String?
  rejectionReason String?
  aiTags      String[]
  aiScore          Float?
  aiRecommendation AiApplicationRecommendation?
  aiReasoning      String?
  duplicateFlag    Boolean           @default(false)
  archetype        String?
  archetypeScores  Json?
  personalizedCopy String?
  templateId       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  answers  ApplicationAnswer[]
  template ApplicationTemplate? @relation(fields: [templateId], references: [id])

  @@index([workspaceId])
  @@index([templateId])
}

model ApplicationAnswer {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  questionKey   String
  answer        String
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

enum EventAccessMode {
  OPEN
  TICKETED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum EventVisibility {
  public
  members_only
  unlisted
}

enum ServiceFeeMode {
  absorb
  pass_stripe_only
  pass_stripe_plus_markup
  flat_per_ticket
}

enum RefundPolicy {
  none
  window
  credit
}

enum WaitlistPromotion {
  none
  same_tier_only
  next_tier_current_price
  next_tier_held_price
}

model Event {
  id               String          @id @default(cuid())
  workspaceId      String
  workspace        Workspace       @relation(fields: [workspaceId], references: [id])
  slug             String
  title            String
  description      String?
  /// Full public hero image URL (e.g. Vercel Blob). Used directly as img src.
  heroImageAssetId      String?
  startAt          DateTime
  endAt            DateTime?
  location         String?
  /// Optional deep link (Google Maps, Apple Maps, etc.).
  mapsUrl               String?
  capacity         Int?
  accessMode            EventAccessMode @default(OPEN)
  approvalRequired      Boolean         @default(false)
  plusOnesAllowed       Boolean         @default(false)
  status                EventStatus     @default(DRAFT)
  showCapacity          Boolean         @default(false)
  priceInCents          Int?
  nonMemberPriceInCents Int?
  refundWindowHours     Int?
  runOfShow             String?         @db.Text
  template              String          @default("editorial")
  eventAccess           Json            @default("{\"member\":{\"enabled\":true,\"gate\":\"auto_confirm\",\"priceCents\":0},\"guest\":{\"enabled\":false,\"gate\":\"pay\",\"priceCents\":0},\"comp\":{\"enabled\":false,\"budgetCap\":null}}")

  // Recurring — seriesId links to EventSeries
  seriesId              String?
  instanceNumber        Int?
  recurrenceRule        String?
  series                EventSeries?    @relation(fields: [seriesId], references: [id])

  // Visibility & calendar
  visibility            EventVisibility @default(public)
  publishesAt           DateTime?
  featured              Boolean         @default(false)

  // Group buy
  groupBuyEnabled                 Boolean @default(true)
  requireAttendeeDetailsPerTicket Boolean @default(false)

  // Service fees
  serviceFeeMode       ServiceFeeMode @default(absorb)
  serviceFeePercentBps Int?
  serviceFeeFlatCents  Int?

  // Refund policy default (tier can override)
  defaultRefundPolicy  RefundPolicy   @default(window)

  // Waitlist behavior
  waitlistPromotion    WaitlistPromotion @default(same_tier_only)

  // Producer Phase J sync — set when an event originates from or is synced with Producer
  producerEventId      String?         @unique

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  customQuestions EventCustomQuestion[]
  rsvps           RSVP[]
  tickets         Ticket[]
  waitlistEntries WaitlistEntry[]
  ticketTiers     TicketTier[]
  orders          Order[]
  accessTokens    AccessToken[]
  promoCodes      PromoCode[]
  ticketHolds     TicketHold[]
  workflow        EventWorkflow?
  smsConversations SmsConversation[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([visibility])
  @@index([featured])
  @@index([publishesAt])
  @@index([seriesId])
}

/// Flexible workflow gating for an event. Replaces the rigid accessMode enum.
/// `paths` is a WorkflowPath[] (see lib/workflows/types.ts). null templateKey = custom.
model EventWorkflow {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  eventId     String   @unique
  event       Event     @relation(fields: [eventId], references: [id])
  templateKey String?
  paths       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId, eventId])
}

enum FieldType {
  TEXT
  TEXTAREA
  SELECT
  MULTISELECT
  CHECKBOX
  DATE
  EMAIL
  PHONE
}

enum QuestionFlowStep {
  BEFORE_SUBMIT
  AFTER_PAYMENT
  BEFORE_APPROVAL
}

model EventCustomQuestion {
  id           String           @id @default(cuid())
  eventId      String
  event        Event            @relation(fields: [eventId], references: [id])
  workspaceId  String
  label        String
  fieldType    FieldType
  options      String[]
  required     Boolean          @default(false)
  order        Int
  showToMember Boolean          @default(true)
  showToGuest  Boolean          @default(true)
  whenInFlow   QuestionFlowStep @default(BEFORE_SUBMIT)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([workspaceId])
  @@index([eventId])
}

enum RSVPStatus {
  CONFIRMED
  DECLINED
  WAITLISTED
}

model RSVP {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  eventId     String
  event       Event      @relation(fields: [eventId], references: [id])
  memberId    String
  member      Member     @relation(fields: [memberId], references: [id])
  status             RSVPStatus @default(CONFIRMED)
  ticketStatus       String     @default("confirmed")
  origin             String     @default("direct")
  plusOneOfMemberId  String?
  customAnswers      Json?
  checkedIn          Boolean    @default(false)
  checkedInAt        DateTime?
  stripePaymentIntentId String?
  paymentStatus      String?
  capturedAt         DateTime?
  amountCents        Int?
  refundedAt         DateTime?
  refundAmountCents  Int?
  isComp             Boolean    @default(false)
  compType           String?
  guestEmail         String?
  guestName          String?

  // Order / tier / token linkage
  orderId            String?
  order              Order?        @relation(fields: [orderId], references: [id])
  tierId             String?
  tier               TicketTier?   @relation(fields: [tierId], references: [id])
  accessTokenId      String?
  accessToken        AccessToken?  @relation(fields: [accessTokenId], references: [id])

  // Per-attendee fields (group buy + requireAttendeeDetailsPerTicket)
  attendeeName          String?
  attendeeEmail         String?
  attendeePhone         String?
  attendeeCustomAnswers Json?

  // Day-of reminder dedupe
  reminderSentAt        DateTime?

  // Plus-one capture (Task 10)
  plusOneName           String?
  plusOneInstagram      String?

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  tickets Ticket[]

  @@unique([workspaceId, eventId, memberId])
  @@index([workspaceId])
  @@index([eventId])
  @@index([orderId])
  @@index([tierId])
}

enum TicketStatus {
  AUTHORIZED
  CAPTURED
  REFUNDED
  CANCELLED
}

model Ticket {
  id                    String       @id @default(cuid())
  workspaceId           String
  workspace             Workspace    @relation(fields: [workspaceId], references: [id])
  eventId               String
  event                 Event        @relation(fields: [eventId], references: [id])
  memberId              String
  member                Member       @relation(fields: [memberId], references: [id])
  rsvpId                String
  rsvp                  RSVP         @relation(fields: [rsvpId], references: [id])
  stripePaymentIntentId String?
  amount                Int
  currency              String
  status                TicketStatus
  walletPassId          String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  payments Payment[]

  @@index([workspaceId])
  @@index([eventId])
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
  COMP
}

model Payment {
  id                    String        @id @default(cuid())
  workspaceId           String
  workspace             Workspace     @relation(fields: [workspaceId], references: [id])
  ticketId              String
  ticket                Ticket        @relation(fields: [ticketId], references: [id])
  stripePaymentIntentId String
  amount                Int
  currency              String
  status                PaymentStatus
  capturedAt            DateTime?
  refundedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([workspaceId])
  @@index([ticketId])
}

model WaitlistEntry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id])
  memberId    String?
  member      Member?   @relation(fields: [memberId], references: [id])
  email       String
  name        String
  position    Int
  notifiedAt  DateTime?
  claimedAt   DateTime?
  expiresAt   DateTime?
  promotedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([eventId])
}

enum AuditActorType {
  OPERATOR
  AGENT
  MEMBER
  SYSTEM
}

model AuditEvent {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])
  actorId     String?
  actorType   AuditActorType @default(OPERATOR)
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([workspaceId])
  @@index([entityType, entityId])
}

/// A Cmd+K agent session. One per palette agent-mode entry (Phase 1 — no resumption).
model AgentConversation {
  id          String   @id @default(cuid())
  workspaceId String
  operatorId  String
  createdAt   DateTime @default(now())
  lastTurnAt  DateTime @default(now())
  /// Auto-generated from the first user message, max 80 chars.
  title       String?

  turns     AgentTurn[]
  workspace Workspace   @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([operatorId])
}

/// One step in an agent conversation: a user message, an assistant message,
/// a tool call, or a tool result.
model AgentTurn {
  id                 String          @id @default(cuid())
  conversationId     String
  role               AgentTurnRole
  /// User message or assistant text.
  content            String?
  toolName           String?
  toolInput          Json?
  toolOutput         Json?
  status             AgentTurnStatus @default(COMPLETED)
  confirmationPrompt String?
  createdAt          DateTime        @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum AgentTurnRole {
  USER
  ASSISTANT
  TOOL_CALL
  TOOL_RESULT
}

enum AgentTurnStatus {
  PENDING
  AWAITING_CONFIRMATION
  COMPLETED
  CANCELLED
  FAILED
}

model RedList {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  email           String?
  namePattern     String?
  reason          String?
  addedByPersonId String?
  createdAt       DateTime  @default(now())

  @@index([workspaceId])
  @@index([email])
}

enum WatchListType {
  PURPLE
  BLOCKED
}

model WatchList {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id])
  type        WatchListType
  matchEmail  String?
  matchPhone  String?
  matchInstagram String?
  note        String?
  createdBy   String?
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?

  @@index([workspaceId])
  @@index([workspaceId, type])
  @@index([matchEmail])
  @@index([matchPhone])
  @@index([matchInstagram])
}

model QuestionDefinition {
  id                  String   @id @default(cuid())
  workspaceId         String
  templateId          String
  stableKey           String
  label               String
  type                String
  section             String
  order               Int
  required            Boolean  @default(false)
  isActive            Boolean  @default(true)
  insightLabel        String
  insightDescription  String
  scoringDimension    String?
  scoringWeight       Float    @default(0.5)
  scoringLogic        String
  archetypeSignals    String[]
  sponsorRelevance    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace   Workspace           @relation(fields: [workspaceId], references: [id])
  template    ApplicationTemplate @relation(fields: [templateId], references: [id])

  @@index([workspaceId])
  @@index([templateId])
  @@index([stableKey])
}

model ApplicationTemplate {
  id                    String   @id @default(cuid())
  workspaceId           String
  name                  String
  description           String?
  slug                  String
  isActive              Boolean  @default(true)
  isDefault             Boolean  @default(false)
  scoringInstructions   String
  archetypesEnabled     Boolean  @default(true)
  memberWorthEnabled    Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  workspace    Workspace            @relation(fields: [workspaceId], references: [id])
  questions    QuestionDefinition[]
  applications Application[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model EventFlowTemplate {
  id                    String    @id @default(cuid())
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  name                  String
  accessMode            String
  applyMode             String?
  priceInCents          Int?
  nonMemberPriceInCents Int?
  approvalRequired      Boolean   @default(false)
  plusOnesAllowed       Boolean   @default(false)
  showCapacity          Boolean   @default(false)
  customQuestions       Json      @default("[]")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([workspaceId])
}

model IntelligenceInsight {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  metricId     String
  narrative    String
  delta        Json?
  generatedAt  DateTime  @default(now())
  acknowledged Boolean   @default(false)

  @@index([workspaceId])
  @@index([metricId])
}

model SavedReport {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  question    String
  metricIds   String[]
  filters     Json
  createdById String
  createdAt   DateTime  @default(now())
  lastRunAt   DateTime?

  @@index([workspaceId])
}

// ============================================================================
// TICKETING V2 — EventSeries, TicketTier, Order, AccessToken, PromoCode
// ============================================================================

enum TierVisibility {
  public
  secret_link
  members_only
}

enum TierTrigger {
  previous_sold_out
  date
  manual
}

enum AccessTokenType {
  secret_link
  comp
}

enum DiscountType {
  percent
  flat
  comp
}

enum TagEntityType {
  member
  event
  series
  order
  application
  rsvp
}

enum TagSource {
  manual
  tenur
  activecampaign
  beehiiv
  system
}

model EventSeries {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  name        String
  description String?
  recurrenceRule String
  startsAt    DateTime
  endsAt      DateTime?
  count       Int?

  // Defaults inherited by instances on creation
  defaultHeroImageAssetId String?
  defaultDescription      String?
  defaultAccessMode       EventAccessMode @default(OPEN)
  defaultPlusOnesAllowed  Boolean         @default(false)
  defaultRefundPolicy     RefundPolicy    @default(window)
  brandColorHex           String?

  active      Boolean @default(true)

  events        Event[]
  ticketTiers   TicketTier[]
  promoCodes    PromoCode[]
  orders        Order[]
  seriesSponsors SeriesSponsor[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([active])
}

model SeriesSponsor {
  id             String   @id @default(cuid())
  workspaceId    String
  seriesId       String
  sponsorBrandId String
  tier           String?
  startInstance  Int?
  endInstance    Int?

  series       EventSeries         @relation(fields: [seriesId], references: [id])
  sponsorBrand SponsorBrandProfile @relation(fields: [sponsorBrandId], references: [id])

  createdAt      DateTime @default(now())

  @@unique([seriesId, sponsorBrandId])
  @@index([workspaceId])
}

model TicketTier {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // XOR: exactly one of eventId or seriesId must be set
  eventId     String?
  seriesId    String?
  event       Event?       @relation(fields: [eventId], references: [id])
  series      EventSeries? @relation(fields: [seriesId], references: [id])

  name        String
  description String?
  imageUrl    String?
  perksJson   Json?
  sortOrder   Int      @default(0)

  // Pricing — null = not purchasable by that audience
  memberPriceCents    Int?
  nonMemberPriceCents Int?

  // Inventory
  quantity  Int
  soldCount Int @default(0)
  heldCount Int @default(0)

  // Availability
  startsAt   DateTime?
  endsAt     DateTime?
  visibility TierVisibility @default(public)

  // Auto-progression
  autoOpenTrigger TierTrigger?
  previousTierId  String?
  previousTier    TicketTier?  @relation("TierProgression", fields: [previousTierId], references: [id])
  nextTiers       TicketTier[] @relation("TierProgression")

  // Order limits
  minPerOrder Int @default(1)
  maxPerOrder Int @default(10)

  // Refund policy override (null = inherit from Event.defaultRefundPolicy)
  refundPolicy      RefundPolicy?
  refundWindowHours Int?

  // Manual override
  manuallyOpened Boolean @default(false)
  manuallyClosed Boolean @default(false)

  rsvps        RSVP[]
  accessTokens AccessToken[]
  promoCodes   PromoCode[]
  ticketHolds  TicketHold[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, eventId])
  @@index([workspaceId, seriesId])
  @@index([visibility])
}

model TicketHold {
  id          String   @id @default(cuid())
  workspaceId String
  tierId      String
  eventId     String?
  quantity    Int
  expiresAt   DateTime
  orderId     String?

  tier        TicketTier @relation(fields: [tierId], references: [id])
  event       Event?     @relation(fields: [eventId], references: [id])

  @@index([workspaceId])
  @@index([tierId, expiresAt])
  @@index([expiresAt])
}

model Order {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // XOR: eventId for single-event orders, seriesId for season pass orders
  eventId     String?
  seriesId    String?
  event       Event?       @relation(fields: [eventId], references: [id])
  series      EventSeries? @relation(fields: [seriesId], references: [id])

  buyerMemberId String?
  buyerName     String
  buyerEmail    String
  buyerPhone    String?

  subtotalCents      Int
  serviceFeeCents    Int @default(0)
  promoDiscountCents Int @default(0)
  totalCents         Int

  stripePaymentIntentId String?       @unique
  paymentStatus         PaymentStatus @default(PENDING)

  promoCodeId String?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id])

  rsvps       RSVP[]
  redemptions PromoRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, eventId])
  @@index([workspaceId, seriesId])
  @@index([buyerMemberId])
  @@index([paymentStatus])
}

model AccessToken {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  eventId     String?
  tierId      String?

  type      AccessTokenType
  tokenHash String          @unique
  maxUses   Int?
  usedCount Int             @default(0)
  expiresAt DateTime?

  compAttendeeName  String?
  compAttendeeEmail String?
  createdByPersonId String?

  event Event?      @relation(fields: [eventId], references: [id])
  tier  TicketTier? @relation(fields: [tierId], references: [id])
  rsvps RSVP[]

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([eventId])
  @@index([tierId])
  @@index([type])
}

model PromoCode {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // XOR: eventId or seriesId; tierId narrows further
  eventId  String?
  seriesId String?
  tierId   String?

  code          String
  discountType  DiscountType
  discountValue Int

  maxUses            Int?
  maxUsesPerCustomer Int?
  validFrom          DateTime?
  validUntil         DateTime?
  usedCount          Int       @default(0)

  event       Event?       @relation(fields: [eventId], references: [id])
  series      EventSeries? @relation(fields: [seriesId], references: [id])
  tier        TicketTier?  @relation(fields: [tierId], references: [id])
  redemptions PromoRedemption[]
  orders      Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, code])
  @@unique([seriesId, code])
  @@index([workspaceId])
}

model PromoRedemption {
  id               String   @id @default(cuid())
  workspaceId      String
  promoCodeId      String
  orderId          String
  amountSavedCents Int
  redeemedAt       DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  order     Order     @relation(fields: [orderId], references: [id])

  @@index([workspaceId])
  @@index([promoCodeId])
  @@index([orderId])
}

model Tag {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String // human-readable: "austin-local", "VIP"
  slug           String // URL-safe normalized
  category       String? // operator grouping: "source", "interest", "campaign"
  color          String? // hex for UI
  description    String?
  externalSource TagSource @default(manual)
  externalId     String? // ID in source system (Tenur tag, AC tag, Beehiiv segment)

  entityTags EntityTag[]
  workspace  Workspace   @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@unique([workspaceId, externalSource, externalId])
  @@index([workspaceId])
  @@index([externalSource])
  @@index([category])
}

model EntityTag {
  id          String        @id @default(cuid())
  workspaceId String
  tagId       String
  entityType  TagEntityType
  entityId    String
  appliedBy   String? // userId, "system", or source name
  appliedAt   DateTime      @default(now())

  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([tagId, entityType, entityId])
  @@index([workspaceId, entityType, entityId])
  @@index([tagId])
}

model SponsorBrandProfile {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  icp          String?
  icpTags      String[]
  category     String?
  primaryColor String?
  logoAssetId  String?

  generatedAssets GeneratedAsset[]
  seriesSponsors  SeriesSponsor[]
  workspace       Workspace        @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model GeneratedAsset {
  id                 String    @id @default(cuid())
  workspaceId        String
  sponsorBrandId     String?
  type               String // simple String for now; promote to enum later
  pdfUrl             String
  magicLinkUrl       String    @unique
  generatedAt        DateTime  @default(now())
  generatedBySession String?
  expiresAt          DateTime?
  payload            Json

  sponsorBrand SponsorBrandProfile? @relation(fields: [sponsorBrandId], references: [id])
  workspace    Workspace            @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

// Internal operator-to-operator notes attached to any entity
// (application / member / event / rsvp / generic). Mentions push into
// OperatorNotification on save.
model OperatorComment {
  id          String    @id @default(cuid())
  workspaceId String
  authorId    String
  authorName  String
  entityType  String
  entityId    String
  body        String
  mentions    String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, createdAt])
}

// Internal notifications surfaced in the operator top-bar bell.
// Read state is per-recipient; createdAt is the canonical sort key.
model OperatorNotification {
  id          String    @id @default(cuid())
  workspaceId String
  recipientId String
  type        String
  title       String
  body        String?
  link        String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([recipientId, readAt])
  @@index([workspaceId, createdAt])
}

// Gamified QA testing missions. AI generates a scenario + steps; operator runs
// it in the live platform; checkpoint hits + bug reports + completion accrue
// score. Mission state is honor-system + URL detection on the client.
model QAMission {
  id             String    @id @default(cuid())
  workspaceId    String
  operatorId     String
  operatorName   String
  scenario       String
  missionType    String    // 'speed_run' | 'discovery' | 'workflow' | 'stress_test' | 'bug_hunt'
  difficulty     String    // 'easy' | 'medium' | 'hard'
  targetSteps    Json      // Array of { id, instruction, checkpoint, points }
  completedSteps Json      @default("[]")
  score          Int       @default(0)
  bugsFound      Json      @default("[]")
  feedback       String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMs     Int?
  status         String    @default("active") // 'active' | 'completed' | 'abandoned'

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, operatorId])
  @@index([workspaceId, status])
  @@index([workspaceId, score])
}

// Workspace-defined membership tiers — replaces the hardcoded top/mid/low
// buckets. Order is operator-controlled (lowest tier = order 0). minScore
// (0–1 canonical aiScore) keeps the bucket/gate semantics derivable from a
// member's score; setting it null means anyone qualifies.
model MembershipTier {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  order       Int       @default(0)
  minScore    Float?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, order])
}

// House Phone — shared multi-operator SMS inbox for live events.
// Direct Twilio send/receive (see the Twilio override note in CLAUDE.md, 2026-05-22).
enum SmsDirection {
  INBOUND
  OUTBOUND
}

model SmsConversation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  phone       String
  name        String?
  eventId     String?
  event       Event?    @relation(fields: [eventId], references: [id])
  aiEnabled   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  messages SmsMessage[]

  @@unique([workspaceId, phone])
  @@index([workspaceId])
}

model SmsMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   SmsConversation @relation(fields: [conversationId], references: [id])
  direction      SmsDirection
  body           String          @db.Text
  aiGenerated    Boolean         @default(false)
  // AI topic label for inbound messages (e.g. "Parking", "Guest List").
  // Null until the categorization job (GET /api/sms/categorize) processes it.
  category       String?
  createdAt      DateTime        @default(now())

  @@index([conversationId, createdAt])
}

// Append-only log of member engagement signals. Feeds network-capital scoring,
// intelligence, and sponsor reporting. Fire-and-forget writes (lib/engagement.ts).
model MemberEngagementEvent {
  id          String   @id @default(cuid())
  workspaceId String
  memberId    String
  eventType   MemberEngagementEventType
  eventId     String?
  metadata    Json?
  occurredAt  DateTime @default(now())

  member      Member    @relation(fields: [memberId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([memberId])
  @@index([occurredAt])
}

enum MemberEngagementEventType {
  rsvp_confirmed
  rsvp_cancelled
  checked_in
  waitlist_joined
  waitlist_promoted
  application_submitted
  newsletter_opened
  sponsor_perk_clicked
}

// ─────────────────────────────────────────────────────────────────────────────
// Digital Asset Manager (Stage 15) — operator media library + share surfaces.
// All assets live PRIVATE in R2; the app mints signed URLs at render time.
// ─────────────────────────────────────────────────────────────────────────────

enum AssetFileType {
  PHOTO
  VIDEO
}

enum MediaFolderType {
  FULL_GALLERY
  SELECTS
  VIDEO
  SPONSOR
  BRAND
}

enum ShareLinkMode {
  SPONSOR
  MEMBER_GALLERY
}

model Asset {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id])
  filename      String
  url           String // R2 object key for the private full-res original
  thumbnailUrl  String // R2 object key for the 800px thumbnail
  blurhash      String?
  fileType      AssetFileType
  size          Int // bytes (per-asset; workspace total tracked as BigInt)
  width         Int?
  height        Int?
  duration      Float? // seconds, video only
  shootDate     DateTime? // EXIF DateTimeOriginal; default sort key, falls back to createdAt
  tags          String[]      @default([]) // manual
  aiTags        String[]      @default([]) // AI auto-tags (separate from manual)
  qualityScore  Float? // heuristic overall (Phase 1)
  qualityScores Json? // breakdown { sharpness, exposure, ... }
  energyLevel   String? // low | medium | high (inferred from scene labels)
  shooterCredit String? // photographer credit
  /// Full-text search vector — maintained by the dam_asset_search_vector trigger
  /// (filename + tags + aiTags + sponsorName). GIN-indexed in prisma/sql/dam-search-vector.sql.
  searchVector  Unsupported("tsvector")?
  isSelect      Boolean       @default(false)
  sortOrder     Int           @default(0) // manual ordering
  folderId      String?
  folder        MediaFolder?  @relation(fields: [folderId], references: [id])
  eventId       String? // plain string + index, NO FK (mirrors Event.heroImageAssetId)
  sponsorName   String?
  uploadedBy    String // Clerk userId
  deletedAt     DateTime? // soft delete; null = live, set = trashed (30-day recover)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  downloads AssetDownload[]

  @@index([workspaceId])
  @@index([folderId])
  @@index([eventId])
  @@index([deletedAt])
}

model MediaFolder {
  id                String          @id @default(cuid())
  workspaceId       String
  workspace         Workspace       @relation(fields: [workspaceId], references: [id])
  name              String
  type              MediaFolderType
  eventId           String? // plain string + index, no FK
  parentId          String?
  parent            MediaFolder?    @relation("FolderTree", fields: [parentId], references: [id])
  children          MediaFolder[]   @relation("FolderTree")
  usageRightsExpiry DateTime?
  sortOrder         Int             @default(0)
  deletedAt         DateTime? // soft delete (folders)
  createdAt         DateTime        @default(now())

  assets     Asset[]
  shareLinks ShareLink[]

  @@index([workspaceId])
  @@index([eventId])
  @@index([parentId])
}

model ShareLink {
  id               String        @id @default(cuid())
  workspaceId      String
  workspace        Workspace     @relation(fields: [workspaceId], references: [id])
  token            String        @unique
  folderId         String
  folder           MediaFolder   @relation(fields: [folderId], references: [id])
  mode             ShareLinkMode
  password         String? // bcrypt hash, optional
  expiresAt        DateTime?
  firstAccessedAt  DateTime? // set on first access → triggers operator email
  lastAccessedAt   DateTime?
  accessCount      Int           @default(0)
  brandingOverride Json? // { logo, primaryColor, companyName }
  customDomain     String?       @unique
  watermark        Boolean       @default(false)
  allowedDownloads Int?
  createdAt        DateTime      @default(now())

  downloads AssetDownload[]

  @@index([workspaceId])
  @@index([folderId])
}

model AssetDownload {
  id           String     @id @default(cuid())
  workspaceId  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id])
  assetId      String
  asset        Asset      @relation(fields: [assetId], references: [id])
  shareLinkId  String?
  shareLink    ShareLink? @relation(fields: [shareLinkId], references: [id])
  downloadedAt DateTime   @default(now())

  @@index([workspaceId])
  @@index([assetId])
  @@index([shareLinkId])
}

/// DYNAMIC = re-evaluated on read via lib/segments/evaluate.ts. STATIC = frozen
/// at creation into SegmentSnapshotMember and never re-evaluated (no re-freeze
/// action exists yet — later work).
enum SegmentKind {
  DYNAMIC
  STATIC
}

/// Slice 4 (Segments, saved views & the operator-action log) — a reusable,
/// named audience of people. Distinct from SavedReport (a saved dashboard
/// metric query, no people-membership semantics) and from WatchList (a raw
/// email/phone/instagram suppression match-list). A "saved view" is just a
/// Segment with kind: DYNAMIC created from the lightweight People-list filter
/// bar — one model, not two.
///
/// `definition` is the filter-AST (Json, NOT raw SQL) — see
/// lib/segments/evaluate.ts for the v1 vocabulary. workspaceId is always
/// hard-injected server-side by the evaluator; a definition can never carry
/// its own workspaceId.
///
/// NO action-wiring this slice (no blast, tag, add-to-event, export target) —
/// the object exists, resolves, and is visible. Actions are future work.
model Segment {
  id              String      @id @default(cuid())
  workspaceId     String
  workspace       Workspace   @relation(fields: [workspaceId], references: [id])
  name            String
  description     String?
  definition      Json
  kind            SegmentKind @default(DYNAMIC)
  createdBy       String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastEvaluatedAt DateTime?
  cachedCount     Int?

  snapshotMembers SegmentSnapshotMember[]

  @@index([workspaceId])
}

/// STATIC-segment frozen membership, persisted as a queryable child table (not a
/// Json id-array on Segment) — a snapshot is a real population someone may
/// later query by person/member, not dead storage. Dual-pointer, same rationale
/// as OperatorActionTarget above.
///
/// NO @@unique here, on purpose — dedupe within a segment (no duplicate row for
/// the same person or the same member) is enforced by two partial unique
/// indexes applied out-of-band (raw SQL, not representable in Prisma's
/// @@unique, which can't express a WHERE clause):
///   SegmentSnapshotMember_segment_person_key on ("segmentId","personId") WHERE "personId" IS NOT NULL
///   SegmentSnapshotMember_segment_member_key on ("segmentId","memberId") WHERE "memberId" IS NOT NULL
/// Same landmine class as ChannelSubscription_person_channel_stream_key — see
/// CLAUDE.md's "Schema changes: never prisma db push" section. A db push would
/// see these as drift and drop them.
model SegmentSnapshotMember {
  id        String   @id @default(cuid())
  segmentId String
  segment   Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  personId  String?
  person    Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  memberId  String?
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([segmentId])
  @@index([personId])
  @@index([memberId])
}


# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# DIRECT_URL — Neon UNPOOLED host (no `-pooler` in the hostname).
# `prisma migrate` / `migrate resolve` and any hand-applied DDL (CREATE TYPE,
# ALTER TYPE ... ADD VALUE, triggers/functions, views) MUST run off PgBouncer —
# transaction pooling can fail or behave inconsistently for DDL. Referenced by
# `directUrl` in prisma/schema.prisma. Same DB as DATABASE_URL, unpooled endpoint.
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Resend (email)
RESEND_API_KEY=re_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Webhooks
# NOTE: code reads SVIX_API_KEY (lib/svix.ts). SVIX_SECRET is a no-op — getSvix()
# returns null and outbound webhooks silently never fire.
SVIX_API_KEY=
PRODUCER_WEBHOOK_URL=https://producer.example.com/api/webhooks/nobc-os/event-notify
PRODUCER_WEBHOOK_SECRET=

# AI
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev Toolbar (optional — omit in production for non-dev users)
# Comma-separated Clerk user IDs allowed to see the floating dev toolbar and
# call /api/dev/seed + /api/dev/reset. Works on any deployment including prod.
# Set BOTH to the same comma-separated Clerk user IDs. NEXT_PUBLIC_ gates the
# UI (DevToolbar pill/panel/hotkey + Settings → Developer via lib/dev-users.ts;
# local dev is always allowed, prod/preview require an entry, empty = nobody);
# the non-public version independently gates the /api/dev/* routes. Changing
# NEXT_PUBLIC_ requires a redeploy — it is inlined at build time.
NEXT_PUBLIC_DEV_USER_IDS=
DEV_USER_IDS=

# Cron — day-of reminder endpoint requires this header to authenticate.
# Vercel Cron sends `x-vercel-cron-secret`; production deploys must set this.
CRON_SECRET=

# Instagram Story Automation (optional — leave empty to disable publishing)
# Required for /api/stories/schedule + cron publishing: Business account ID + long-lived access token.
# Obtain from Meta for Developers business login flow; scopes: instagram_business_basic, instagram_business_content_publish.
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# Application Backup → Google Drive (the company's most critical data asset).
# Code-complete but DORMANT (fail-closed) until ALL THREE are set: a backup is
# left PENDING and reconciled automatically by the hourly cron once creds exist.
# Use a Google Cloud service account with Drive access; share the target folder
# with the service-account email. The Drive client is dependency-free (signed
# service-account JWT → OAuth token → Drive v3 REST — no googleapis dep).
#   _EMAIL         — service account email (…@…iam.gserviceaccount.com)
#   _PRIVATE_KEY   — service account RSA private key PEM (\n-escaped newlines OK)
#   _FOLDER_ID     — Drive folder id that receives the YYYY-MM backup subfolders
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
